# Core mapping workbooks
DFRE_INPUT_DIR=C:\Users\sipoX\Documents\DFRE\code\WebscrapingDeliveryAvailability\data\input
EW_LSOA_WORKBOOK=C:\Users\sipoX\Documents\DFRE\code\WebscrapingDeliveryAvailability\data\input\England and Wales - one postcode per LSOA.xlsx
SCOTLAND_DZ_WORKBOOK=C:\Users\sipoX\Documents\DFRE\code\WebscrapingDeliveryAvailability\data\input\AllDZ_OnePostcodePerDZ_RUC_SeeNotesTab.xlsx

# Optional polygons. GeoJSON features must contain LSOA21CD or DZCode, or an area_id property.
EW_LSOA_GEOJSON_FILE=
SCOTLAND_DZ_GEOJSON_FILE=

# Optional England/Wales centroids for point fallback. Expected columns: area_id, lon, lat. Optional: area_name
EW_LSOA_CENTROIDS_FILE=

# Local data option. Files may be .csv or .parquet.
DELIVERY_MAP_FILE=
RESTAURANT_PROFILE_FILE=

# Dashboard coverage cache. Dash reads this first and never needs the full BigQuery source tables.
AREA_COVERAGE_FILE=data/cache/area_delivery_coverage.parquet
COVERAGE_LABEL=weekday_full_20260520

# BigQuery option for building/downloading the lightweight analysis table.
BQ_PROJECT_ID=delivery-availability-research
BQ_DATASET_ID=delivery_availability
BQ_DELIVERY_MAP_TABLE=postcode_restaurant_delivery_map
BQ_RESTAURANT_PROFILE_TABLE=restaurant_profile
BQ_AREA_MAPPING_TABLE=area_representative_postcodes
BQ_AREA_COVERAGE_TABLE=area_delivery_coverage
BQ_MAX_ROWS=0

# App behavior
USE_DEMO_DATA=true
DASH_HOST=127.0.0.1
DASH_PORT=8050



